# ==============================================================================
# Local Development Environment configuration (Outside of Docker)
# Source this file before executing the application:
# $ source configs/local-dev.env && go run cmd/main.go
# ==============================================================================

# Service Identity & Metadata
SERVICE_NAME=mango-parental-control
SERVICE_TYPE=mango-parental-control
SERVICE_VERSION=dev
ENVIRONMENT=dev

# Ports & Connectivity
HTTP_PORT=16008
PRIVATE_HTTP_PORT=17008
SYSTEM_URI_PRIVATE=https://localhost:17008
SYSTEM_URI_PUBLIC=https://localhost:16008
SYSTEM_URI_UI=https://localhost

# Database Configuration (PostgreSQL running on localhost via exposed ports)
# Note: Defaulting to the standard superuser 'postgres' credentials and database ensures out-of-the-box
# connectivity without manual user/schema creation on local and container setups.
STORAGE_TYPE=postgresql
STORAGE_TYPE_POSTGRESQL_HOST=localhost
STORAGE_TYPE_POSTGRESQL_PORT=5432
STORAGE_TYPE_POSTGRESQL_USERNAME=postgres
STORAGE_TYPE_POSTGRESQL_PASSWORD=postgres
STORAGE_TYPE_POSTGRESQL_DATABASE=postgres
STORAGE_TYPE_POSTGRESQL_SSLMODE=disable

# Kafka Messaging Configuration (Kafka running on localhost via exposed ports)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=mango-parental-control
KAFKA_GROUP_ID=mango-parental-control-group

# Service Discovery Configuration
# DISCOVERY_ENABLED: If true, registers the service with the service discovery mesh via Kafka.
DISCOVERY_ENABLED=false
# SERVICE_RPC_ENABLED: If true, enables the RPC client factory for communication with other services.
SERVICE_RPC_ENABLED=false
DISCOVERY_TOPIC=service_events
DISCOVERY_ORDERING=round-robin
SYSTEM_INSTANCE_KEY=changeme

# Authentication & TLS Certificates Configuration
# Relative paths pointing to certificates in the local workspace directory
# Ensure certificates are generated or copied to ./certs
INTERNAL_RESTAPI_HOST_CERT=./certs/restapi-cert.pem
INTERNAL_RESTAPI_HOST_KEY=./certs/restapi-key.pem
INTERNAL_RESTAPI_HOST_ROOTCA=./certs/restapi-ca.pem

# Structured Logging Configuration
# LOG_LEVEL options: debug, info, warn, error
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_ADD_SOURCE=true

# Authentication Configuration
# AUTH_ENABLED: Enables token validation on the public API interface. If true, public endpoints
# require Bearer tokens validated against the security service (owsec). For local dev, set to false.
AUTH_ENABLED=false
