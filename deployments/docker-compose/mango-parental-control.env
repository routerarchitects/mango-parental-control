# ==============================================================================
# OpenWiFi Docker Compose Environment Template
# This file is generated dynamically for integration with mango-cloud-deployment.
# Copy this file to: /openwifi-sdk/mango-cloud-deployment/docker-compose/mango-parental-control.env
# ==============================================================================

# Service Identity & Metadata
SERVICE_NAME=mango-parental-control
SERVICE_TYPE=mango-parental-control
SERVICE_VERSION=dev
ENVIRONMENT=dev

# Ports & Connectivity
HTTP_PORT=16008
PRIVATE_HTTP_PORT=17008
SYSTEM_URI_PRIVATE=https://mango-parental-control.wlan.local:17008
SYSTEM_URI_PUBLIC=https://openwifi.wlan.local:16008
SYSTEM_URI_UI=https://openwifi.wlan.local

# Database Configuration (PostgreSQL)
# Note: Defaulting to the standard superuser 'postgres' credentials and database ensures out-of-the-box
# connectivity without manual user/schema creation on local and container setups.
STORAGE_TYPE=postgresql
STORAGE_TYPE_POSTGRESQL_HOST=postgresql
STORAGE_TYPE_POSTGRESQL_PORT=5432
STORAGE_TYPE_POSTGRESQL_USERNAME=postgres
STORAGE_TYPE_POSTGRESQL_PASSWORD=postgres
STORAGE_TYPE_POSTGRESQL_DATABASE=mango-parental-control
STORAGE_TYPE_POSTGRESQL_SSLMODE=disable

# Kafka Messaging Configuration
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=mango-parental-control
KAFKA_GROUP_ID=mango-parental-control-group

# Service Discovery Configuration
# DISCOVERY_ENABLED: If true, registers the service with the service discovery mesh via Kafka.
DISCOVERY_ENABLED=true
# SERVICE_RPC_ENABLED: If true, enables the RPC client factory for communication with other services.
SERVICE_RPC_ENABLED=true
DISCOVERY_TOPIC=service_events
DISCOVERY_ORDERING=round-robin
SYSTEM_INSTANCE_KEY=changeme

# Authentication & TLS Certificates Configuration
# Mounted into the container's standard security paths
INTERNAL_RESTAPI_HOST_CERT=/app/certs/restapi-cert.pem
INTERNAL_RESTAPI_HOST_KEY=/app/certs/restapi-key.pem
INTERNAL_RESTAPI_HOST_ROOTCA=/app/certs/restapi-ca.pem

# Structured Logging Configuration
# LOG_LEVEL options: debug, info, warn, error
LOG_LEVEL=info
LOG_FORMAT=text
LOG_ADD_SOURCE=false

# Authentication Configuration
# AUTH_ENABLED: Enables token validation on the public API interface. If true, public endpoints
# require Bearer tokens validated against the security service (owsec).
AUTH_ENABLED=true
